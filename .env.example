AISTUDY_PUBLIC_DATA_ROOT=F:\AIstudyPublicData
AISTUDY_PUBLIC_RUNTIME_ROOT=F:\AIstudyPublicData\runtime

# Public runtime reads only the four MySQL connection fields below.
# Database is fixed to aistudy_public; table names are fixed and cannot be overridden by env.
AISTUDY_PUBLIC_MYSQL_HOST=127.0.0.1
AISTUDY_PUBLIC_MYSQL_PORT=3306
AISTUDY_PUBLIC_MYSQL_USER=root
AISTUDY_PUBLIC_MYSQL_PASSWORD=
